PORT=5000
MONGODB_URI=mongodb://localhost:27017/eduvault

# Firebase Admin SDK configuration
# You can generate a private key JSON from Firebase Console -> Project Settings -> Service Accounts.
# For production/deployment (Render), paste the entire JSON object as a single line string.
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "YOUR_PROJECT_ID", ...}

# Alternatively, if running locally, you can specify individual variables:
FIREBASE_PROJECT_ID=your-firebase-project-id
